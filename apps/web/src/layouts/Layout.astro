---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nitide, les scores Open Food Facts pendant tes courses en ligne',
  description = 'Extension Chrome qui affiche Nutri-Score, Green-Score et Nova directement sur les sites de courses. Open source, sans tracking.',
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1F3D2B" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Marks JS availability so scroll-reveal styles only hide content when the
         reveal script will actually run (no-JS users see everything). -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono&family=Instrument+Serif:ital@0;1&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
