---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

// Demo products, real Open Food Facts data (frozen snapshot).
const good = {
  name: 'Maïs doux',
  img: '/demo/mais-doux.jpg',
  price: '1,29 €',
  scores: [
    { v: 'A', color: '#008240', label: 'Nutri' },
    { v: 'B', color: '#78B14F', label: 'Green' },
    { v: '1', color: '#448747', label: 'Nova' },
  ],
  off: 'https://world.openfoodfacts.org/product/3017800237113',
};
const bad = {
  name: 'Kinder Bueno',
  brand: 'Kinder',
  img: '/demo/kinder-bueno.jpg',
  price: '1,89 €',
  scores: [
    { v: 'E', color: '#E63312', label: 'Nutri' },
    { v: 'E', color: '#E8471B', label: 'Green' },
    { v: '4', color: '#E73834', label: 'Nova' },
  ],
};
const grades = [
  ['A', '#008240', 'Nutri-Score', 'Qualité nutritionnelle'],
  ['B', '#78B14F', 'Green-Score', 'Impact environnemental'],
  ['1', '#448747', 'Nova', 'Degré de transformation (1 = brut)'],
];
const levels = [
  ['Matières grasses', 'Faible', '#008240'],
  ['Saturés', 'Faible', '#008240'],
  ['Sucres', 'Modéré', '#EE8100'],
  ['Sel', 'Faible', '#008240'],
];
const nutrition = [
  ['Énergie', '77 kcal'],
  ['Matières grasses', '1,8 g'],
  ['dont saturés', '0,4 g'],
  ['Glucides', '11 g'],
  ['dont sucres', '5 g'],
  ['Fibres', '2,8 g'],
  ['Protéines', '2,7 g'],
];
const steps = [
  ['Installe Nitide', "Ajoute l'extension à Chrome en un clic."],
  ['Fais tes courses', 'Va sur Carrefour.fr comme d’habitude.'],
  ['Compare d’un coup d’œil', 'Les scores s’affichent sur les produits, le détail sur la fiche.'],
];
const features = [
  ['Sans friction', 'Pas de scan, pas d’appli à ouvrir. Les scores sont là, sur les produits.'],
  ['Ta vie privée d’abord', 'Aucune donnée collectée, aucun tracking, aucun compte.'],
  [
    'Trois angles, pas un',
    'Nutrition (Nutri-Score), environnement (Green-Score) et transformation (Nova), plus le détail sur la fiche.',
  ],
  [
    'Des données fiables',
    'Les scores viennent d’Open Food Facts, la base alimentaire collaborative.',
  ],
];
const faq = [
  ['C’est vraiment gratuit ?', 'Oui, et sans pub. C’est un projet personnel, pas un business.'],
  ['Sur quels sites ça marche ?', 'Carrefour.fr pour commencer. D’autres enseignes viendront.'],
  [
    'Qu’est-ce que vous faites de mes données ?',
    'Rien : Nitide ne collecte aucune donnée et ne te piste pas. Les scores des listes sont calculés en local ; seule la fiche produit interroge Open Food Facts, sans aucune information personnelle.',
  ],
  [
    'D’où viennent les scores ?',
    'D’Open Food Facts, la base de données alimentaire ouverte (licence ODbL).',
  ],
  ['Pourquoi un produit n’a pas de score ?', 'Parce qu’il n’est pas encore dans Open Food Facts.'],
];

const sectionTitle = 'mb-10 text-center text-4xl text-green-dark';
// Small UI labels in the demo panel use the sans font (Geist), not the serif
// that global CSS applies to h1-h3.
const h3Sub = 'mb-2.5 font-sans text-[11px] font-bold uppercase tracking-[0.06em] text-ink-muted';
---

<Layout>
  <main class="flex min-h-screen flex-col">
    <!-- Hero -->
    <section class="px-6 pt-28 pb-16 text-center sm:pt-36 sm:pb-20">
      <div class="mx-auto max-w-2xl">
        <div class="brand-lockup mb-8 flex items-center justify-center gap-3.5">
          <svg
            class="brand-mark"
            aria-hidden="true"
            width="60"
            height="60"
            viewBox="0 0 64 64"
            fill="none"
          >
            <rect width="64" height="64" rx="14" fill="#1F3D2B"></rect>
            <path
              d="M18 46 V18 L42 40 V18"
              stroke="#FAF6EE"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"></path>
            <circle cx="46" cy="46" r="3" fill="#D4A24C"></circle>
          </svg>
          <span class="brand-name font-serif text-6xl text-green-dark sm:text-7xl">Nitide</span>
        </div>

        <h1 class="mb-5 text-4xl leading-[1.08] text-green-dark sm:text-5xl">
          Vois <em class="italic">clair</em> dans tes courses.
        </h1>
        <p class="mx-auto mb-8 max-w-lg text-lg text-ink-muted">
          Nitide affiche le Nutri-Score, le Green-Score et le Nova sur chaque produit, directement
          sur ton site de courses. Sans scanner, sans tracking.
        </p>

        <a
          href="#"
          class="inline-block rounded-full bg-amber-ocre px-7 py-3.5 font-semibold text-[#2a1d05] shadow-lg shadow-amber-ocre/30 transition hover:brightness-105"
        >
          Ajouter à Chrome
        </a>
        <p class="mt-4 text-sm text-ink-muted">Gratuit · Sans pub · Aucune donnée collectée</p>
      </div>
    </section>

    <!-- Demo -->
    <section class="px-6 pb-20">
      <div class="mx-auto max-w-5xl">
        <h2 class={sectionTitle}>Concrètement, <em class="italic">ça donne ça</em>.</h2>

        <div class="grid items-start gap-10 md:grid-cols-[1fr_minmax(0,21rem)] md:gap-12">
          <!-- List tiles -->
          <div>
            <p class="mb-4 text-xs font-semibold uppercase tracking-[0.07em] text-green-sage">
              Sur les listes de produits
            </p>
            <div class="grid grid-cols-2 gap-4">
              {
                [good, bad].map((p) => (
                  <article class="rounded-2xl border border-border-soft bg-white p-3.5 shadow-sm">
                    <img
                      src={p.img}
                      alt={p.name}
                      width="440"
                      height="440"
                      loading="lazy"
                      class="mb-3 aspect-square w-full rounded-xl bg-white object-contain"
                    />
                    <p class="text-sm font-semibold leading-tight">{p.name}</p>
                    {'brand' in p && p.brand ? (
                      <p class="text-xs text-ink-muted">{p.brand}</p>
                    ) : null}
                    <p class="mb-3 mt-1 text-[15px] font-bold">{p.price}</p>
                    <div class="inline-flex items-stretch overflow-hidden rounded-xl border border-border-soft bg-cream">
                      {p.scores.map((s, i) => (
                        <span
                          class:list={[
                            'flex flex-col items-center gap-1 px-2.5 py-1.5',
                            i > 0 && 'border-l border-border-soft',
                          ]}
                        >
                          <span
                            class="flex h-6 w-6 items-center justify-center rounded-full text-[13px] font-extrabold text-white"
                            style={`background:${s.color}`}
                          >
                            {s.v}
                          </span>
                          <span class="text-[8px] font-bold uppercase tracking-[0.07em] text-ink-muted">
                            {s.label}
                          </span>
                        </span>
                      ))}
                    </div>
                  </article>
                ))
              }
            </div>
          </div>

          <!-- Detail panel -->
          <div>
            <p class="mb-4 text-xs font-semibold uppercase tracking-[0.07em] text-green-sage">
              Sur la fiche produit
            </p>
            <div
              class="overflow-hidden rounded-2xl border border-border-soft bg-white text-[13px] leading-snug shadow-xl"
            >
              <div class="flex items-center gap-2 border-b border-border-soft bg-cream px-4 py-3">
                <svg class="h-[22px] w-[22px]" viewBox="0 0 64 64" aria-hidden="true">
                  <rect width="64" height="64" rx="14" fill="#1F3D2B"></rect>
                  <path
                    d="M18 46 V18 L42 40 V18"
                    stroke="#FAF6EE"
                    stroke-width="4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    fill="none"></path>
                  <circle cx="46" cy="46" r="3" fill="#D4A24C"></circle>
                </svg>
                <span class="font-bold text-green-dark">
                  Nitide
                  <span class="block text-[11px] font-medium text-ink-muted">{good.name}</span>
                </span>
              </div>

              <div class="px-4 py-3.5">
                <div>
                  <h3 class={h3Sub}>Scores</h3>
                  <div class="space-y-2.5">
                    {
                      grades.map(([v, color, name, expl]) => (
                        <div class="flex items-center gap-3">
                          <span
                            class="flex h-[34px] w-[34px] flex-none items-center justify-center rounded-full text-base font-extrabold text-white"
                            style={`background:${color}`}
                          >
                            {v}
                          </span>
                          <span>
                            <span class="font-bold">{name}</span>
                            <br />
                            <span class="text-xs text-ink-muted">{expl}</span>
                          </span>
                        </div>
                      ))
                    }
                  </div>
                </div>

                <div class="mt-4 border-t border-[#F1ECE0] pt-4">
                  <h3 class={h3Sub}>Repères nutritionnels</h3>
                  <div class="grid grid-cols-2 gap-2">
                    {
                      levels.map(([name, lvl, color]) => (
                        <div class="flex items-center gap-2 rounded-lg bg-cream px-2.5 py-1.5">
                          <span
                            class="h-2.5 w-2.5 flex-none rounded-full"
                            style={`background:${color}`}
                          />
                          <span class="flex-1 text-xs">{name}</span>
                          <span class="text-[11px] font-bold" style={`color:${color}`}>
                            {lvl}
                          </span>
                        </div>
                      ))
                    }
                  </div>
                </div>

                <details class="nutri mt-4 border-t border-[#F1ECE0] pt-4">
                  <summary
                    class="flex cursor-pointer items-center justify-between text-[11px] font-bold uppercase tracking-[0.06em] text-ink-muted"
                  >
                    Valeurs nutritionnelles / 100 g
                  </summary>
                  <table class="w-full border-collapse text-[12.5px]">
                    {
                      nutrition.map(([k, v]) => (
                        <tr class="border-b border-[#F4EFE4] last:border-0">
                          <td class="py-1">{k}</td>
                          <td class="py-1 text-right font-bold tabular-nums">{v}</td>
                        </tr>
                      ))
                    }
                  </table>
                </details>

                <div class="mt-4 border-t border-[#F1ECE0] pt-4">
                  <h3 class={h3Sub}>Caractéristiques</h3>
                  <div class="flex flex-wrap gap-1.5">
                    {
                      ['Végan', 'Végétarien', 'Sans huile de palme'].map((b) => (
                        <span class="rounded-full border border-[#DDE6D8] bg-[#EEF3EC] px-2.5 py-0.5 text-[11px] font-semibold text-green-dark">
                          {b}
                        </span>
                      ))
                    }
                  </div>
                  <p class="mt-2 text-xs text-ink-muted">
                    <b class="font-semibold text-ink">Additifs :</b> aucun
                  </p>
                </div>
              </div>

              <div
                class="border-t border-border-soft bg-cream px-4 py-2.5 text-[11px] text-ink-muted"
              >
                Source :
                <a href={good.off} class="font-semibold text-green-dark" rel="noopener">
                  Open Food Facts
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Comment ça marche -->
    <section class="border-y border-border-soft bg-white px-6 py-20">
      <div class="mx-auto max-w-5xl">
        <h2 class={sectionTitle}>Comment ça marche</h2>
        <div class="grid gap-8 md:grid-cols-3">
          {
            steps.map(([title, body], i) => (
              <div>
                <span class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-full bg-green-dark font-bold text-cream">
                  {i + 1}
                </span>
                <h3 class="mb-1.5 text-2xl text-green-dark">{title}</h3>
                <p class="text-ink-muted">{body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Pourquoi Nitide -->
    <section class="px-6 py-20">
      <div class="mx-auto max-w-5xl">
        <h2 class={sectionTitle}>Pourquoi Nitide</h2>
        <div class="grid gap-5 md:grid-cols-2">
          {
            features.map(([title, body]) => (
              <div class="rounded-2xl border border-border-soft bg-white p-6">
                <h3 class="mb-2 text-2xl text-green-dark">{title}</h3>
                <p class="text-ink-muted">{body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-t border-border-soft bg-white px-6 py-20">
      <div class="mx-auto max-w-2xl">
        <h2 class={sectionTitle}>Questions fréquentes</h2>
        <div>
          {
            faq.map(([q, a]) => (
              <div class="border-b border-border-soft py-5 first:border-t">
                <p class="mb-1.5 font-semibold">{q}</p>
                <p class="text-ink-muted">{a}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>

<style>
  /* Brand lockup: gentle entrance, plus a slow soft glint sweeping across the
     wordmark. Subtle but eye-catching. Disabled for reduced-motion users. */
  @media (prefers-reduced-motion: no-preference) {
    .brand-lockup {
      animation: brand-rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .brand-mark {
      transform-origin: center;
      animation: brand-rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .brand-name {
      background: linear-gradient(
        100deg,
        #1f3d2b 0%,
        #1f3d2b 47%,
        #4a6a4c 50%,
        #1f3d2b 53%,
        #1f3d2b 100%
      );
      background-size: 300% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      animation: brand-glint 9s linear 1.5s infinite;
    }
  }
  @keyframes brand-rise {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  /* The ocre band is off-screen at both ends (text shows plain green), so it
     sweeps across exactly once per cycle with no visible jump on loop. */
  @keyframes brand-glint {
    from {
      background-position: 150% 0;
    }
    to {
      background-position: -150% 0;
    }
  }

  /* Collapsible nutrition disclosure: hide the native marker, add a chevron,
     and animate open/close (Chrome ::details-content; instant fallback elsewhere). */
  .nutri > summary {
    list-style: none;
  }
  .nutri > summary::-webkit-details-marker {
    display: none;
  }
  .nutri > summary::after {
    content: '\25BE';
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .nutri[open] > summary {
    margin-bottom: 10px;
  }
  .nutri[open] > summary::after {
    transform: rotate(180deg);
  }
  .nutri::details-content {
    height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      height 0.22s ease,
      opacity 0.22s ease,
      content-visibility 0.22s allow-discrete;
  }
  .nutri[open]::details-content {
    height: auto;
    opacity: 1;
  }
</style>
