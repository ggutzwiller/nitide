{
  "name": "@nitide/core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared OFF client, types, product matching and cache utilities for Nitide.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./off-client": {
      "types": "./src/off-client.ts",
      "default": "./src/off-client.ts"
    },
    "./cache": {
      "types": "./src/cache.ts",
      "default": "./src/cache.ts"
    },
    "./matching": {
      "types": "./src/matching.ts",
      "default": "./src/matching.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
