{
  "name": "nitide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension that displays Open Food Facts scores on online grocery websites.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Grégoire Gutzwiller",
  "homepage": "https://nitide.fr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggutzwiller/nitide.git"
  },
  "bugs": {
    "url": "https://github.com/ggutzwiller/nitide/issues"
  },
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm -r --filter \"./apps/*\" build",
    "test": "pnpm -r --if-present test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck && pnpm typecheck:scripts",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json",
    "icons:generate": "tsx scripts/generate-icons.ts",
    "dataset:build": "duckdb < scripts/build-scores-fr.sql && tsx scripts/build-scores-dataset.ts",
    "clean": "pnpm -r exec rm -rf dist .astro .output node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
